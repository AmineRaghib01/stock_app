NODE_ENV=development
PORT=4000

# Postgres — same style as your other app (DATABASE_URL is built if omitted)
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=stockflow_db
DB_HOST=db
DB_PORT=5432

# Prisma CLI (db push, migrate, studio) reads this from .env — kept in sync with DB_* above
DATABASE_URL="postgresql://postgres:admin123@db:5432/stockflow_db?schema=public"

JWT_SECRET=dev-portfolio-jwt-secret-change-in-real-deployment-min-32
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads
