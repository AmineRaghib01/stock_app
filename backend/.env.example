NODE_ENV=development
PORT=4000

# Postgres (matches common Express apps)
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=postgres
DB_HOST=localhost
DB_PORT=5432

# Prisma CLI reads this from .env — must match DB_* (or omit DB_* and only use this line)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/postgres?schema=public"

JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads
